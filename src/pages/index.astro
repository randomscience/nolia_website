---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/sections/Hero.astro';
import SplitPanel from '@components/sections/SplitPanel.astro';
import Features from '@components/sections/Features.astro';
import Stats from '@components/sections/Stats.astro';
import { featureLists } from '@data/features';
import { statsLists } from '@data/stats';
import Logos from '@components/sections/Logos.astro';
import { logoLists } from '@data/logos';
import CtaBanner from '@components/sections/CtaBanner.astro';
import Faqs from '@components/sections/Faqs.astro';
import { faqLists } from '@data/faqs';
import RecentPosts from '@components/sections/RecentPosts.astro';
import heroImage from '../assets/images/home/default-hero-2.jpg';
import styleGuideImage from '../assets/images/home/business-lady.jpg';
import iconSpolecznosc from '@assets/icons/spolecznosc.svg';
import iconRezerwacje from '@assets/icons/rezerwacje.svg';
import iconFormalnosci from '@assets/icons/formalnosci.svg';
import FeatureCards from "@components/ui/FeatureCard.astro";

import  dostawcyImage  from '@assets/sections/dostawcy.svg';
import  placowkiImage  from '@assets/sections/placowki.svg';
import  seniorzyImage  from '@assets/sections/seniorzy.svg';

const seoTitle = "NOLIA - Zajęcia dla seniorów w Twojej okolicy";
const seoDescription = "Znajdź zajęcia, kursy i spotkania dla seniorów. Zapomnij o nudzie - odkryj tysiące możliwości w Twojej okolicy na jednej bezpiecznej platformie."

const cards = [
  {
    title: "PLACÓWKA",
    utitle: "Dla placówek opieki i instytucji",
    description: `Zarządzaj zajęciami, aktywizacją uczestników i współpracą ze specjalistami w jednym miejscu.
<br/>
<br/>
**Funkcjonalności**:
- harmonogram zajęć i aktywności
- dostęp do sprawdzonych usługodawców
- zarządzanie uczestnikami
- raportowanie i monitoring postępów
- gotowe programy aktywizacyjne
`,
    bgColor: "--card-green",
    image: placowkiImage,,
  },
  {
    title: "USŁUGODAWCA",
    utitle: "Dla trenerów, terapeutów i specjalistów",
    description: `Docieraj do placówek i uczestników bez sprzedaży „od drzwi do drzwi”.
<br/>
<br/>
**Funkcjonalności**:
- dostęp do klientów (placówki i uczestnicy)
- zarządzanie grafikiem
- rozliczenia i płatności
- budowanie własnej marki
- gotowe programy zajęć`,
    bgColor: "--card-beige",
    image: dostawcyImage,
  },
  {
    title: "UCZESTNIK",
    utitle: "Dla uczestników i ich rodzin",
    description: `Znajdź zajęcia, opiekę i aktywności dopasowane do swoich potrzeb i możliwości.
<br/>
<br/>
**Funkcjonalności**:
- dostęp do zajęć i wydarzeń
- wybór specjalistów
- łatwe zapisy i płatności
- programy zdrowotne i rozwojowe
- wsparcie w codziennej aktywności
`,
    bgColor: "--card-orange",
    image: seniorzyImage,
  },
];


const heroContent = {
    title: 'Aktywne życie zaczyna się tutaj',
    description: 'Łączymy placówki, specjalistów i uczestników, aby tworzyć zajęcia, opiekę i aktywności, które realnie poprawiają jakość życia.',
    buttons: [
        // {
        //     text: 'Subskrybuj newsletter',
        //     link: '/contact',
        //     target: '_self',
        //     variant: 'accent' as const
        // },
        // {
        //     text: 'Napisz do nas',
        //     link: '/contact',
        //     target: '_self',
        //     variant: 'accent' as const
        // }
    ],
    backgroundImage: heroImage,
    overlayOpacity: 0.8
}

const featuresSection = {
    eyebrow: "DLACZEGO NOLIA?",
    title: "Bezpieczna platforma łącząca seniorów z zajęciami na ich miarę",
    description: "NOLIA to więcej niż aplikacja. To cały ekosystem zaprojektowany z myślą o Tobie - od wyszukiwania zajęć, przez bezpieczne płatności, aż po całodobową obsługę klienta. Wszystkie organizatorzy są zweryfikowani i posiadają opinie realnych uczestników.",
    features: featureLists.main.features,
    button: null 
    // {
    //     text: "Dowiedz się więcej",
    //     link: "/theme-info",
    //     variant: "primary" as const
    // }
}

const FooterCta = {
    eyebrow: "DOŁĄCZ DO NASZEJ SPOŁECZNOŚCI",
    title: 'Życie jest zbyt krótkie, by nie wychodzić z domu',
    description: 'Miliony seniorów na całym świecie już odkrywają nowe pasje, przyjaźnie i możliwości. Bądź następny!',
    hideCta: true,
    button: {
        text: 'Subskrybuj newsletter',
        link: '/contact',
        target: '_self'
    }
}

const styleGuideSection = {
    eyebrow: "DLA PLACÓWEK I ORGANIZATORÓW",
    headline: "Rozwijaj swoją działalność dzięki NOLIA",
    // description: "Połącz się z szerszą społecznością seniorów poszukujących zajęć. Zarządzaj rezerwacjami, otrzymuj opinie i automatyczne wypłaty. NOLIA dba o wszystkie formalne aspekty - umowy, ubezpieczenia, obsługa klienta. Ty skupiasz się na tym, co robisz najlepiej.",
    points: [
        {
            text: "Połącz się z szerszą społecznością seniorów poszukujących zajęć.",
            icon: iconSpolecznosc
        },
        {
            text: "Zarządzaj rezerwacjami, otrzymuj opinie i automatyczne wypłaty.",
            icon: iconRezerwacje
        },
        {
            text: "NOLIA dba o wszystkie formalne aspekty - umowy, ubezpieczenia, obsługa klienta. Ty skupiasz się na tym, co robisz najlepiej.",
            icon: iconFormalnosci
        },
    ],
    image: {
        src: styleGuideImage,
        alt: "Featured image"
    },
    buttons: [
        // {
        //     text: "Dowiedz się więcej",
        //     link: "/style-guide",
        //     variant: "accent" as const
        // }
    ]
}

const sideBySideStats = {
    eyebrow: "Stats",
    title: "Built for Speed and Flexibility",
    description: "Titan Core is designed with performance and developer experience in mind. Our lightweight theme gives you all the essentials without the bloat, letting you build exactly what you need with impressive speed.",
    variant: 'side-by-side' as const,
    stats: statsLists.withContent.stats,
    content: {
        title: "Built for Speed and Flexibility",
        description: "Titan Core is designed with performance and developer experience in mind. Our lightweight theme gives you all the essentials without the bloat, letting you build exactly what you need with impressive speed.",
        button: {
            text: "Discover Titan Core",
            link: "/theme-info",
            variant: "primary" as const
        }
    }
};

const mainCta = {
    eyebrow: "GOTOWY NA NOWĄ PRZYGODĘ?",
    title: "Dołącz do tysięcy aktywnych seniorów",
    description: "Bądź na bieżąco — zapisz się do naszego newslettera, by otrzymywać informacje o nowych zajęciach i wydarzeniach.",
    features: featureLists.main.features,
    button: {
        text: "Subskrybuj newsletter",
        link: "/contact",
        variant: "primary" as const
    }
};


const logosSection = {
    headline: "Nasi partnerzy:",
    logos: logoLists.main.logos
}

const faqsSection = {
    eyebrow: "FAQ",
    title: 'Najczęściej zadawane pytania',
    description: 'Poniżej przedstawiamy listę najczęściej zadawanych pytań. Jeżeli Twoje pytanie się tam nie pojawiło [napisz do nas!](/contact)',
    faqs: faqLists.main.faqs,
}

const recentPostsSection = {
    eyebrow: "LATEST INSIGHTS",
    title: " Learn From Our Experience",
    description: "Explore our latest articles on Astro JS development, theme customization tips, and web performance best practices.",
    button: {
            text: "View All Posts",
            link: "/blog",
        variant: "primary" as const
    }
}
---

<Layout footerCta={FooterCta} title={seoTitle} description={seoDescription}>
    <Hero content={heroContent} />
    <FeatureCards cards={cards} />
    <!-- <RecentPosts content={recentPostsSection} background="base" padding="base" postsToShow={3} category="Theme Usage"/> -->
    <Features content={featuresSection} background="light" padding="base"  />
    <!-- <Logos content={logosSection} background="base" padding='small'/> -->
    <!-- <Faqs content={faqsSection} background="light" padding="small" /> -->


    
    <SplitPanel content={styleGuideSection} imagePosition="right" background="base" padding="base" />
    <CtaBanner content={mainCta} variant="contained" background="light" paddingBottom="base" />

    
    <!-- <Stats content={sideBySideStats} background='dark' padding="base"/> -->
</Layout>
