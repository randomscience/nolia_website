---
import Button from '@components/ui/Button.astro';
import { Image } from 'astro:assets';
import heroImage from '@assets/images/hero.svg';
interface HeroContent {
    title: string;
    description: string;
    heroImage: any;
    circleBg?: string;
    buttons?: {
        text: string;
        link: string;
        variant?: 'primary' | 'secondary' | 'ghostLight' | 'ghostDark' | 'accent';
        target?: string;
    }[];
}

const { content } = Astro.props;
---

<section class="bg-[var(--hero-bg)] header-offset overflow-hidden">
    <div class="site-container mx-auto px-16 pt-16 pb-0">
        <div class="grid md:grid-cols-2 items-center gap-12">

            <!-- LEFT CONTENT -->
            <div class="max-w-xl">
                <h1 class="text-4xl md:text-5xl font-bold text-[var(--hero-title)] leading-tight">
                    {content.title}
                </h1>

                <div class="w-16 h-1 bg-[var(--hero-accent)] my-6"></div>

                <p class="text-[var(--hero-text)]">
                    {content.description}
                </p>

                {content.buttons && (
                    <div class="flex flex-wrap gap-4 mt-8">
                        {content.buttons.map((button) => (
                            <Button
                                href={button.link}
                                target={button.target || '_self'}
                                variant={button.variant || 'primary'}
                            >
                                {button.text}
                            </Button>
                        ))}
                    </div>
                )}
            </div>

            <!-- RIGHT IMAGE -->
            <div class="relative flex justify-center md:justify-end">

                <!-- decorative circle -->
                <div
                    class="absolute w-[500px] h-[500px] rounded-full 
                           bg-[var(--hero-circle)] 
                           opacity-60 
                           top-1/2 -translate-y-1/2"
                ></div>

                <!-- hero image -->
                <Image
                    src={heroImage}
                    alt=""
                    class="relative z-10 w-full max-w-lg"
                    loading="eager"
                />
            </div>

        </div>
    </div>
</section>