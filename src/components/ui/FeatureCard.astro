---
import { Image } from 'astro:assets';
import Button from './Button.astro';

import { marked } from 'marked';

interface Card {
  title: string;
  utitle: string;
  description: string;
  bgColor: string;   // CSS variable
  image: string;     // foreground SVG
}

const { cards } = Astro.props;
---
<section class="bg-background-light overflow-hidden">
    <div class="site-container mx-auto px-2">
<div class="grid md:grid-cols-3 px-8">
  {cards.map((card) => (
    <div class="flex flex-col px-8 grid grid-rows-subgrid row-span-4 gap-0">
      
      <!-- text -->
      <h3 class="text-xl font-semibold padding mt-8">
        {card.title}
      </h3>

      <div class:list={["text-gray-500 text-small list-disc"]} style="list-style-type: circle" set:html={marked(card.utitle)} ></div>

      <!-- image container -->
      <div
        class="relative w-full items-center justify-center max-w-[360px] aspect-[4/3] rounded-2xl flex"
        style={`background-color: var(${card.bgColor});`}
      >
        <Image
          src={card.image}
          alt={card.title}
          class="relative z-10  w-4/5 object-contain"
        />
      </div>

      {/* <p class="mt-3 text-gray-500 text-sm leading-relaxed max-w-[260px]">
        {card.description}
      </p> */}

    <div class:list={["pt-8 text-gray-500 text-small list-disc"]} style="list-style-type: circle" set:html={marked(card.description)} ></div>


      <!-- button -->
      {/* <Button variant="primary" class="mt-6">
        Dowiedz się więcej
      </Button> */}
    </div>
  ))}
</div>
    </div>
</section>